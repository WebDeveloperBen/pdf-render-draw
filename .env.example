# ============================================
# PDF Annotator Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# Database
# ============================================
# Local development: Use Docker Compose (docker compose up -d)
# Production: Neon serverless PostgreSQL with Cloudflare Hyperdrive
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pdf_annotate"

# ============================================
# Authentication (Better Auth)
# ============================================
BETTER_AUTH_SECRET=""                   # Generate with: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000" # Your app's public URL

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# Cloudflare R2 Storage
# ============================================
# Public URL for serving assets (custom domain or R2.dev URL)
R2_PUBLIC_URL="" # e.g., https://assets.your-domain.com

# Note: R2 bucket is configured as a binding in wrangler.toml
# The binding name is R2_BUCKET and maps to your bucket

# ============================================
# Payments (optional)
# ============================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# AI Features (optional)
# ============================================
ANTHROPIC_API_KEY=""

# ============================================
# Email (optional)
# ============================================
NUXT_RESEND_API_KEY=""

# ============================================
# Cloudflare Deployment Notes
# ============================================
# 1. Database: Create a Hyperdrive connection to your Neon database
#    wrangler hyperdrive create pdf-annotator-db --connection-string="$DATABASE_URL"
#
# 2. R2 Storage: Create an R2 bucket and configure in wrangler.toml
#    wrangler r2 bucket create pdf-annotator-assets
#
# 3. Secrets: Set via Cloudflare dashboard or wrangler CLI
#    wrangler secret put BETTER_AUTH_SECRET
#    wrangler secret put DATABASE_URL
#    etc.
