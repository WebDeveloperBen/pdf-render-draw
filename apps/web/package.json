{
  "name": "@pdf-annotator/web",
  "version": "0.1.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:seed": "tsx scripts/seed-dev.ts && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "check": "nuxt typecheck",
    "generate-api": "tsx scripts/generate-api.ts",
    "clean-api": "orval --clean",
    "lint": "eslint . --fix",
    "format": "npx prettier --write '**/*.{ts,vue}'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:prod": "vitest run --config vitest.integration.prod.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-dev.ts",
    "db:seed-owner": "tsx scripts/seed-owner.ts",
    "db:setup": "drizzle-kit push && tsx scripts/seed-dev.ts",
    "auth:generate": "dlx @better-auth/cli@latest generate",
    "cf:types": "wrangler types",
    "cf:preview": "nuxt build && wrangler dev .output/server/index.mjs --assets .output/public",
    "cf:deploy": "nuxt build && wrangler deploy .output/server/index.mjs --assets .output/public",
    "clean": "rm -rf .nuxt .output dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@better-auth/api-key": "^1.5.4",
    "@better-auth/stripe": "^1.5.4",
    "@internationalized/date": "^3.10.0",
    "@internationalized/number": "^3.6.5",
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/fonts": "^0.12.1",
    "@nuxtjs/color-mode": "4.0.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/vue-query": "^5.92.0",
    "@tanstack/vue-query-devtools": "^6.1.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "@vue-email/compiler": "^0.8.14",
    "@vue-email/components": "^0.0.21",
    "@vue-email/render": "^0.0.9",
    "@vueform/multiselect": "^2.6.11",
    "@vueform/slider": "^2.1.10",
    "apexcharts": "^5.3.6",
    "better-auth": "^1.5.4",
    "dexie": "^4.2.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "embla-carousel": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "eslint": "^9.39.1",
    "jspdf": "^3.0.4",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.577.0",
    "motion-v": "^1.7.4",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.2.1",
    "orval": "^7.17.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.394",
    "pg": "^8.13.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.6.0",
    "resend": "^6.6.0",
    "stripe": "^20.4.1",
    "svg2pdf.js": "^2.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "transformation-matrix": "^3.1.0",
    "uncrypto": "^0.1.3",
    "uuid": "^13.0.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.24",
    "vue-currency-input": "^3.2.1",
    "vue-email": "^0.8.11",
    "vue-router": "^4.6.3",
    "vue-sonner": "^2.0.9",
    "vue3-apexcharts": "^1.10.0",
    "vuedraggable": "^4.1.0",
    "wrangler": "^4.71.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.57.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/node": "^24.10.1",
    "@types/uuid": "^11.0.0",
