    "@vueuse/nuxt": "^14.0.0",
    "@yuta-inoue-ph/nuxt-vcalendar": "^1.1.3",
    "drizzle-kit": "^0.31.7",
    "happy-dom": "^20.0.11",
    "playwright-core": "^1.56.1",
    "tailwindcss-animate": "^1.0.7",
    "testcontainers": "^11.13.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.12",
    "vue-tsc": "^3.1.4"
  }
}
