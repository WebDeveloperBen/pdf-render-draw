{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MetreMate",
  "version": "0.1.0",
  "identifier": "com.metremate.app",
  "build": {
    "frontendDist": "../../web/.output/public",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "pnpm --filter @pdf-annotator/web dev",
    "beforeBuildCommand": "pnpm --filter @pdf-annotator/web build"
  },
  "app": {
    "windows": [
      {
        "title": "MetreMate",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
